# Frontend (Shopify App)
SHOPIFY_API_KEY=<from Shopify Partner Dashboard>
SHOPIFY_API_SECRET=<from Shopify Partner Dashboard>
APP_URL=<public HTTPS URL for OAuth callback, e.g., https://your-domain.com or ngrok URL>
SCOPES=write_products,read_orders

# Frontend Database
DATABASE_URL=file:./data/app.db

# Backend
BACKEND_URL=http://localhost:3004
PORT=3004
NODE_ENV=development

# Backend Database (Postgres)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ai_assistant_db

# Backend CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-prod-domain.com

# Encryption key for secret config fields (generate with: openssl rand -hex 32)
CONFIG_ENCRYPTION_KEY=<64-hex-character-random-string>
